Table students {
  id text [pk]
  name text
}

Table subjects {
  id text [pk]
}

Table enrollments {
  student_id text [ref: > students.id]
  subject_id integer [ref: > subjects.id]
}

Table rooms {
  id text [pk]
}

Table lessons {
  id integer [pk, increment]
  subject_id integer [ref: > subjects.id]
  room_id text [ref: > rooms.id]
  date date 
  slot integer

  Indexes {
    (room_id, slot) [unique] 
  }
}

Table attendances {
  lesson_id integer [ref: > lessons.id]
  student_id text [ref: > students.id]
  present integer

  Indexes {
    (lesson_id, student_id) [pk]
  }
}